---
import type { HeroProps } from '../../content.config';
import '../../styles/hero.css';

type Props = HeroProps;

const { title, subtitle, badge, cta, image, imageAlt } = Astro.props;
---

<section class="hero">
  <div class="hero__inner">
    <div class="hero__content">
      {badge && <span class="hero__badge">{badge}</span>}
      <h1 class="hero__title">{title}</h1>
      <p class="hero__subtitle">{subtitle}</p>
      <a href={cta.href} class="hero__cta">{cta.label}</a>
    </div>

    <div class="hero__media">
      <img src={image} alt={imageAlt} class="hero__image" />
    </div>
  </div>
</section>
